# ── Google Sheets ─────────────────────────────────────────────
# Spreadsheet ID dari URL: docs.google.com/spreadsheets/d/[ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Path ke file credentials service account Google
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Nama sheet tab untuk reminder (default: Reminders)
SHEET_REMINDER_TAB=Reminders
SHEET_MANUAL_TAB=MyReminders

# ── WhatsApp ───────────────────────────────────────────────────
# Nomormu sendiri (untuk terima laporan harian), format: 628xxx
OWNER_NUMBER=628xxxxxxxxxx
ALLOWED_NUMBERS=628xxxxxxxxxx

# (Opsional) Approval untuk !done dari non-approver
# Jika true, maka user yang bukan approver akan kirim request dan status baru berubah setelah disetujui.
DONE_REQUIRE_OWNER_APPROVAL=false
DONE_APPROVAL_TTL_MS=900000

# Siapa saja yang boleh !approve / !reject (default: OWNER_NUMBER).
# Kamu bisa tulis "OWNER_NUMBER" sebagai token.
APPROVER_NUMBERS=OWNER_NUMBER,62xxxxxxxxxx,62yyyyyyyyyy

# Label yang muncul di chat untuk pihak approver (default: Abang)
APPROVER_LABEL=Abang

# Nama untuk nomor (buat tampil "ditandai selesai oleh Nama")
# Format: 628xxx=Nama,628yyy=Nama2
NUMBER_NAME_MAP=62xxxxxxxxxx=Name,62yyyyyyyyyy=Name2

# Untuk reminder auto-import yang read-only (IMPORTRANGE), bot simpan status done di tab ini
SHEET_OVERRIDE_TAB=BotOverrides

# ── Fun sticker command ───────────────────────────────────────
# Path file sticker WebP untuk command !damn (dibuat via !setdamn)
DAMN_STICKER_PATH=./data/damn.webp

# ── Scheduler ─────────────────────────────────────────────────
# Jam pengiriman reminder harian (format 24 jam, WIB = UTC+7)
# Default: setiap hari jam 08:00 pagi
REMINDER_CRON=0 8 * * *

# ── Notifikasi H- berapa hari sebelum deadline ─────────────────
# Pisah dengan koma. Contoh: 7,3,1,0 artinya 7 hari, 3 hari, 1 hari, dan hari H
NOTIFY_DAYS_BEFORE=7,3,1,0
